# =============================================================================
# Matrix Green — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# .env is gitignored and should NEVER be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local example: postgresql://postgres:password@localhost:5432/matrix_green
DATABASE_URL=""

# -----------------------------------------------------------------------------
# NextAuth.js
# -----------------------------------------------------------------------------
# NEXTAUTH_SECRET: Random string used to sign/encrypt tokens.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# NEXTAUTH_URL: The base URL of your app (no trailing slash).
# In production, set this to your deployed URL.
NEXTAUTH_URL="http://localhost:3000"
